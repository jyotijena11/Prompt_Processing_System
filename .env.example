APP_NAME=Prompt Processing System
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/prompt_system
REDIS_URL=redis://redis:6379/0
PROVIDER_RATE_LIMIT_PER_MINUTE=300
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TOP_K=200
PROCESSING_STALE_AFTER_SECONDS=180
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
